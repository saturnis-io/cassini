# =============================================================================
# Cassini Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and edit the values below.
# All variables use the CASSINI_ prefix. The settings loader strips this prefix
# when mapping to internal configuration fields.
#
# Required variables are marked with [REQUIRED].
# Everything else has sensible defaults for local development.
# =============================================================================

# -- Database -----------------------------------------------------------------
# SQLite (default — zero config, great for evaluation and small deployments):
CASSINI_DATABASE_URL=sqlite+aiosqlite:///./cassini.db

# PostgreSQL (recommended for production):
# CASSINI_DATABASE_URL=postgresql+asyncpg://cassini:your-password@localhost:5432/cassini

# MySQL:
# CASSINI_DATABASE_URL=mysql+aiomysql://cassini:your-password@localhost:3306/cassini

# MSSQL:
# CASSINI_DATABASE_URL=mssql+aioodbc://cassini:your-password@localhost:1433/cassini?driver=ODBC+Driver+17+for+SQL+Server

# -- Admin Bootstrap ----------------------------------------------------------
# [REQUIRED on first run] — Creates the initial admin user.
# The admin account is only created when the database has zero users.
# You will be prompted to change this password on first login.
CASSINI_ADMIN_USERNAME=admin
CASSINI_ADMIN_PASSWORD=change-me-on-first-run

# -- Security -----------------------------------------------------------------
# JWT secret for signing access tokens. Auto-generated and persisted to
# .jwt_secret if not set. Set explicitly in production.
# CASSINI_JWT_SECRET=your-random-secret-here

# Encryption key for stored database credentials (Fernet). Auto-generated
# and persisted to .db_encryption_key if not set.
# CASSINI_DB_ENCRYPTION_KEY=your-fernet-key-here

# Set to true when serving over HTTPS (required for secure cookies).
# Set to false for local development over HTTP.
CASSINI_COOKIE_SECURE=false

# -- Server -------------------------------------------------------------------
# CASSINI_HOST=0.0.0.0
# CASSINI_PORT=8000

# -- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
CASSINI_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# -- Rate Limiting ------------------------------------------------------------
# CASSINI_RATE_LIMIT_LOGIN=5/minute
# CASSINI_RATE_LIMIT_DEFAULT=60/minute

# -- Logging ------------------------------------------------------------------
# "console" for human-readable, "json" for structured (production).
# CASSINI_LOG_FORMAT=console

# -- Development Flags --------------------------------------------------------
# Enable sandbox/devtools mode (NEVER enable in production).
# CASSINI_SANDBOX=false

# Dev mode — disables enterprise license enforcement. For development only.
# CASSINI_DEV_MODE=false

# -- Web Push Notifications (optional) ----------------------------------------
# Generate VAPID keys: npx web-push generate-vapid-keys
# CASSINI_VAPID_PRIVATE_KEY=
# CASSINI_VAPID_PUBLIC_KEY=
# CASSINI_VAPID_CONTACT_EMAIL=

# -- Commercial License (optional) --------------------------------------------
# CASSINI_LICENSE_FILE=
# CASSINI_LICENSE_PUBLIC_KEY_FILE=
