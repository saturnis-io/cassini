# Cluster test environment — shared config for all nodes
# Load these into the environment before starting any Cassini node.
#
# IMPORTANT: All nodes MUST share identical values for JWT_SECRET,
# DB_ENCRYPTION_KEY, and DATABASE_URL to function as a cluster.

# Database — PostgreSQL on non-standard port to avoid local collisions
CASSINI_DATABASE_URL=postgresql+asyncpg://cassini:cassini@localhost:5433/cassini_cluster

# Broker — enables cluster mode (requires enterprise tier)
# valkey:// is normalized to redis:// by the broker factory (redis-py compat)
CASSINI_BROKER_URL=valkey://localhost:6379

# Auth — fixed secrets so tokens validate cross-node
CASSINI_JWT_SECRET=cluster-test-jwt-secret-do-not-use-in-production
CASSINI_DB_ENCRYPTION_KEY=cluster-test-encryption-key-not-for-prod

# Licensing — bypass for local testing
CASSINI_DEV_TIER=enterprise
CASSINI_DEV_MODE=true

# Admin bootstrap
CASSINI_ADMIN_PASSWORD=admin123admin

# CORS — allow all API node origins
CASSINI_CORS_ORIGINS=http://localhost:8001,http://localhost:8002,http://localhost:8003

# Cookies — local HTTP (no TLS)
CASSINI_COOKIE_SECURE=false
